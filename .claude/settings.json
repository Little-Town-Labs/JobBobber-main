{
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm format*)",
      "Bash(pnpm type-check*)",
      "Bash(pnpm db:*)",
      "Bash(pnpm inngest:*)",
      "Bash(npx prisma *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Read(~/.ssh/config)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "WebFetch"
    ],
    "ask": ["Bash(git push *)", "Bash(pnpm publish)", "Bash(vercel *)", "Bash(gh *)"]
  },
  "env": {
    "NODE_ENV": "development",
    "NEXT_PUBLIC_APP_URL": "http://localhost:3000"
  },
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": []
  },
  "companyAnnouncements": [
    "JobBobber: AI-powered talent matching with autonomous agent negotiations",
    "Stack: Hybrid T3 (Next.js + tRPC + Prisma) + Inngest workflows",
    "Review README.md for architecture and project-config.json for commands",
    "AI agent workflows go in Inngest (no timeout limits)",
    "Full-stack type safety: tRPC + Prisma + Zod validation",
    "Target 80%+ test coverage - mock LLM API calls in tests",
    "Use pnpm as package manager"
  ],
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["docker", "docker-compose"]
  }
}
